{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arielparra.github.io/credentials/data/credentials.schema.json",
  "title": "Credentials Schema",
  "description": "Schema for the portfolio credentials data",
  "type": "object",
  "properties": {
    "credentials": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "issuer": {
            "type": "string"
          },
          "title": {
            "anyOf": [
              { "type": "string" },
              {
                "type": "object",
                "properties": {
                  "en": { "type": "string" },
                  "es": { "type": "string" }
                },
                "required": ["en", "es"]
              }
            ]
          },
          "level": {
            "anyOf": [
              { "type": "string" },
              {
                "type": "object",
                "properties": {
                  "en": { "type": "string" },
                  "es": { "type": "string" }
                },
                "required": ["en", "es"]
              }
            ]
          },
          "score": {
            "anyOf": [
              { "type": "string" },
              {
                "type": "object",
                "properties": {
                  "en": { "type": "string" },
                  "es": { "type": "string" }
                },
                "required": ["en", "es"]
              }
            ]
          },
          "startedOn": {
            "type": "string",
            "description": "Start date for education entries (YYYY-MM or YYYY-MM-DD)"
          },
          "issuedOn": {
            "type": "string"
          },
          "expiresOn": {
            "type": "string"
          },
          "topics": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "ai",
                "blockchain",
                "cloud",
                "cybersecurity",
                "data-science",
                "database",
                "devops",
                "finance",
                "languages",
                "networking",
                "professional",
                "programming"
              ]
            }
          },
          "skills": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "en": { "type": "string" },
                "es": { "type": "string" }
              },
              "required": ["en", "es"]
            }
          },
          "image": {
            "type": "string"
          },
          "link": {
            "type": "string"
          },
          "description": {
            "type": "object",
            "properties": {
              "en": { "type": "string" },
              "es": { "type": "string" }
            },
            "required": ["en", "es"]
          }
        },
        "required": [
          "id",
          "type",
          "issuer",
          "title",
          "score",
          "issuedOn",
          "topics",
          "skills",
          "image",
          "link",
          "description"
        ]
      }
    }
  },
  "required": ["credentials"]
}
